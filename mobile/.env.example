# Firebase Client SDK (Expo / React Native)
# Copie este arquivo para .env e preencha com suas credenciais.
# Nunca commite o arquivo .env no Git.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# firebase-admin é SOMENTE para backend Node.js (Cloud Functions, scripts).
# Não use serviceAccountKey.json no app mobile.
